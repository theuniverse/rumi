# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# WeWeRSS base URL (internal Docker network)
# WeWeRSS replaces RSSHub for WeChat public account RSS feeds.
# rsshub_path for each Source should be: /feeds/{mpId}.xml
RSSHUB_BASE=http://wewe-rss:4000

# WeWeRSS login password — must match WEWE_AUTH_CODE in docker-compose.yml
# Only needed if you set ENABLE_FEED_AUTH=true in WeWeRSS (default: false)
# WEWE_AUTH_CODE=changeme_wewe

# SQLite path (inside container, mapped to Docker volume)
DATABASE_URL=sqlite+aiosqlite:///./data/scraper.db

# Optional: change model selection
MODEL_CLASSIFY=qwen/qwen-2.5-32b-instruct
MODEL_EXTRACT=qwen/qwen-2.5-72b-instruct
MODEL_DIFF=qwen/qwen-2.5-32b-instruct

# CORS — add your rumi frontend origin
CORS_ORIGINS=["http://localhost:8888","http://localhost:5173"]
