# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# WeWeRSS base URL — local dev: http://localhost:4000, Docker: http://wewe-rss:4000
RSSHUB_BASE=http://localhost:4000

# WeWeRSS AUTH_CODE — must match the AUTH_CODE you set when starting WeWeRSS
# WEWE_AUTH_CODE=changeme_wewe

# SQLite path (inside container, mapped to Docker volume)
DATABASE_URL=sqlite+aiosqlite:///./data/scraper.db

# Model selection (must be valid OpenRouter IDs — see https://openrouter.ai/models)
# qwen3.5-9b: $0.05/1M, 256K context, strong Chinese, accessible from CN
MODEL_CLASSIFY=qwen/qwen3.5-9b
MODEL_EXTRACT=qwen/qwen3.5-9b
MODEL_DIFF=qwen/qwen3.5-9b

# CORS — add your rumi frontend origin
CORS_ORIGINS=["http://localhost:8888","http://localhost:5173"]
