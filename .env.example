# =============================================================================
# Root .env — docker-compose reads this for WeWeRSS service variables.
# Copy to .env and fill in real values before running deploy.sh.
# =============================================================================

# WeWeRSS MySQL password (used by both wewe-rss-db and wewe-rss)
WEWE_DB_PASSWORD=wewe_rss_pass

# WeWeRSS management password — set once, then enter it in Scraper → Settings
WEWE_AUTH_CODE=changeme_wewe

# WeWeRSS external URL (used for generating absolute URLs in HTML)
# IMPORTANT: Change this to your actual domain with /wewerss path
# This fixes Mixed Content errors when accessing via HTTPS
WEWE_SERVER_ORIGIN_URL=http://rumi.website:4000
