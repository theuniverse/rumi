# ── Database ──────────────────────────────────────────────────────────────────
# Docker 环境中 host 使用服务名 "mysql"，本地开发使用 "localhost"
DATABASE_URL=mysql+pymysql://rumi:rumi_pass@mysql:3306/rumi
MYSQL_DATABASE=rumi
MYSQL_USER=rumi
MYSQL_PASSWORD=rumi_pass
MYSQL_ROOT_PASSWORD=change_me_in_production

# ── External APIs ──────────────────────────────────────────────────────────────
# 高德地图 API (https://lbs.amap.com)
AMAP_API_KEY=

# Flomo Webhook (Settings > API in Flomo app)
FLOMO_WEBHOOK_URL=

# Optional: Resident Advisor session cookie for venue data
RA_COOKIE=

# ── CORS ──────────────────────────────────────────────────────────────────────
# 逗号分隔的允许跨域来源，生产环境改为你的域名
# 通过 nginx 代理部署时同源请求不触发 CORS，可留空
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
